// .config/zellij/layouts/test.kdl

layout {
  // Use the current dir when `zellij --layout test`
  cwd ""

  pane size=1 borderless=true {
    plugin location="tab-bar"
  }

  pane split_direction="vertical" {
    pane {
      stacked true
      pane {
        name "File"
        size "80%"
        close_on_exit true
        command "ft"
      }
      pane {
        name "Git"
        size "80%"
        close_on_exit true
        command "keifu"
      }
    }
    pane split_direction="horizontal" size="80%" {
      pane size="65%" {
        focus true
        stacked true

        pane {
          focus true
          name "Editor"
        }
        pane {
          name "Agent"
        }
      }
      pane size="35%" {
        name "Terminal"
      }
    }
  }
  pane size=1 borderless=true {
    plugin location="status-bar"
  }
}
